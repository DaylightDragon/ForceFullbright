{
	"schemaVersion": 1,
	"id": "forcefullbright",
	"version": "${version}",
	"name": "Force Fullbright",
	"description": "Forced Fullbright with uniform lighting. Toggle with /forceFullbright or a keybind.",
	"authors": [
		"Daylight"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/forcefullbright/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
          "org.daylight.forcefullbright.ForceFullbright"
		],
		"client": [
          "org.daylight.forcefullbright.ForceFullbrightClient"
		]
	},
	"mixins": [
		"forcefullbright.mixins.json",
		{
			"config": "forcefullbright.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.14",
		"minecraft": ">=1.21.8",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}